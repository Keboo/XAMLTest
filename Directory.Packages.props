    <PackageVersion Include="MSTest.TestFramework" Version="4.3.0" />
    <PackageVersion Include="System.CommandLine" Version="2.0.9" />
    <PackageVersion Include="System.Drawing.Common" Version="10.0.7" />
    <PackageVersion Include="xunit" Version="2.6.2" />
